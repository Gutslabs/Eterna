{
  "name": "aipex-mcp-bridge",
  "version": "3.1.0",
  "description": "MCP bridge that connects AI agents (Cursor, Claude Code, VS Code Copilot, etc.) to the AIPex browser extension. Auto-spawns a shared daemon to support multiple simultaneous clients.",
  "type": "module",
  "bin": {
    "aipex-mcp-bridge": "./dist/bridge.js",
    "aipex-mcp-daemon": "./dist/daemon.js",
    "aipex-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bridge.ts",
    "dev:daemon": "tsx src/daemon.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "aipex",
    "browser",
    "cursor",
    "claude",
    "copilot",
    "websocket",
    "bridge"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AIPexStudio/aipex-whole.git",
    "directory": "aipex/mcp-bridge"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
